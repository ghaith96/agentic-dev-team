#!/usr/bin/env bash
#
# Auto-bump patch version in plugin.json when plugin content changes.
#
# Triggers when staged files include anything in:
#   agents/ skills/ commands/ hooks/ knowledge/ evals/ docs/ CLAUDE.md README.md
#
# Skips if plugin.json is already staged (manual version bump takes priority).

set -euo pipefail

PLUGIN_JSON=".claude-plugin/plugin.json"

# Skip if plugin.json doesn't exist
[ -f "$PLUGIN_JSON" ] || exit 0

# Skip if plugin.json is already staged (user bumped manually)
if git diff --cached --name-only | grep -q "^\.claude-plugin/plugin\.json$"; then
  exit 0
fi

# Check if any plugin content files are staged
PLUGIN_PATHS="^agents/ ^skills/ ^commands/ ^hooks/ ^knowledge/ ^evals/ ^docs/ ^CLAUDE\.md$ ^README\.md$"
STAGED=$(git diff --cached --name-only)

MATCH=false
for pattern in $PLUGIN_PATHS; do
  if echo "$STAGED" | grep -qE "$pattern"; then
    MATCH=true
    break
  fi
done

# No plugin content changed — skip
$MATCH || exit 0

# Read current version
if ! command -v jq &>/dev/null; then
  echo "pre-commit: jq not found, skipping auto version bump" >&2
  exit 0
fi

CURRENT=$(jq -r '.version // "0.0.0"' "$PLUGIN_JSON")

# Bump patch: 1.1.0 -> 1.1.1
IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
PATCH=$((PATCH + 1))
NEW_VERSION="${MAJOR}.${MINOR}.${PATCH}"

# Update plugin.json
jq --arg v "$NEW_VERSION" '.version = $v' "$PLUGIN_JSON" > "${PLUGIN_JSON}.tmp"
mv "${PLUGIN_JSON}.tmp" "$PLUGIN_JSON"

# Stage the bumped file
git add "$PLUGIN_JSON"

echo "pre-commit: version bumped ${CURRENT} → ${NEW_VERSION}"
